{
  "appId": "com.milansharma.stremfusion",
  "productName": "StremFusion",
  "copyright": "Copyright 2026 Milan Sharma",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../Backend/Tools/scrcpy-win64-v3.3.3",
      "to": "scrcpy",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "nsis",
        "arch": ["x64"]  
      }
    ],
    "icon": "assets/icon-256.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "portable": {
    "artifactName": "StremFusion-v1.2.0-Portable.exe"
  }
}
